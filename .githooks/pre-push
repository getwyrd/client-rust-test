#!/usr/bin/env bash
# Pre-push guard for client-rust-test: never let code that fails the gate's
# static checks leave the machine. Runs the same `make check` that a reviewer
# expects to be green (fmt, clippy -D warnings, cargo check).
#
# This hook is version-controlled under .githooks/. Enable it with:
#     git config core.hooksPath .githooks
#
# Bypass for a work-in-progress push with:  git push --no-verify
set -euo pipefail

# Resolve the repo root so the hook works regardless of the invoking cwd.
repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

if ! command -v make >/dev/null 2>&1; then
    echo "pre-push: 'make' not found; skipping checks." >&2
    exit 0
fi

echo "pre-push: running 'make check' (fmt, clippy -D warnings, check)…"
if ! make check; then
    echo >&2
    echo "pre-push: 'make check' failed — push aborted." >&2
    echo "         Fix the issues, or re-run with 'git push --no-verify' to bypass." >&2
    exit 1
fi

echo "pre-push: checks passed."
